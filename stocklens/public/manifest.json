{
  "manifest_version": 3,
  "name": "StockLens - Technical Analysis Scanner",
  "version": "1.0.0",
  "description": "Pure-math stock scanner with auto ticker detection. Scans momentum, trend, volume, volatility, and price action across multiple timeframes. No AI, no server, no login.",
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://in.finance.yahoo.com/*",
    "https://finance.yahoo.com/*",
    "https://www.tradingview.com/*",
    "https://groww.in/*",
    "https://groww.io/*",
    "https://kite.zerodha.com/*",
    "https://zerodha.com/*",
    "https://www.nseindia.com/*",
    "https://nseindia.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tradingview.com/*",
        "https://groww.in/*",
        "https://groww.io/*",
        "https://kite.zerodha.com/*",
        "https://zerodha.com/*",
        "https://www.nseindia.com/*",
        "https://nseindia.com/*",
        "https://in.finance.yahoo.com/*",
        "https://finance.yahoo.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "StockLens",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.js", "*.wasm", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
